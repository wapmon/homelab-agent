# Copy this file to .env and fill in real values. NEVER commit .env.
# No Anthropic API key needed — run `claude auth login` once to authenticate
# via your Claude Pro/Max subscription.

# --- Proxmox ---
# Create an API token: Datacenter -> Permissions -> API Tokens
# Format: USER@REALM!TOKENID
PROXMOX_HOST=192.168.1.10
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=homelab-agent
PROXMOX_TOKEN_SECRET=
PROXMOX_VERIFY_SSL=false

# --- Home Assistant ---
# Profile -> Security -> Long-Lived Access Tokens
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=

# --- Pi-hole (v6 uses 'password', v5 uses 'token') ---
PIHOLE_URL=http://pi.hole
PIHOLE_PASSWORD=

# --- *arr stack ---
SONARR_URL=http://sonarr.lan:8989
SONARR_API_KEY=
RADARR_URL=http://radarr.lan:7878
RADARR_API_KEY=

# --- Transmission ---
TRANSMISSION_URL=http://transmission.lan:9091/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=

# --- Emby ---
EMBY_URL=http://emby.lan:8096
EMBY_API_KEY=

# --- Uptime Kuma ---
UPTIME_KUMA_URL=http://uptime-kuma.lan:3001
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=

# --- SSH ---
# Path to the private key the agent will use. The corresponding public key
# must be in ~/.ssh/authorized_keys on each target host for the user defined
# in inventory.yaml.
SSH_KEY_PATH=~/.ssh/homelab_agent_ed25519
